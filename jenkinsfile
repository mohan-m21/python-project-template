pipeline {
    agent any

    stages {
        stage('pythonCHECKOUT') {
            steps {
                checkout scmGit(branches: [[name: '*/main']], extensions: [], userRemoteConfigs: [[credentialsId: 'Mohan_GitHub', url: 'https://github.com/mohan-m21/python-project-template.git']])
            }
        }
        stage('python-creating enveronment') {
            steps {
                sh 'python -m venv venv'
                sh '. venv/bin/activate'
            }
        }
        stage('python-installing requirements') {
            steps {
                sh 'pip install -r requirements-test.txt'
            }
        }
        stage('python-compile') {
            steps {
                sh 'python -m compileall .'
            }
        }
        stage('python-TEST') {
            steps {
                sh 'pip install pytest'
                sh 'pytest'
            }
        }
        stage('python-BUILD') {
            steps {
                sh 'pip install build'
                sh 'python -m build'
            }
        }
    }
}
